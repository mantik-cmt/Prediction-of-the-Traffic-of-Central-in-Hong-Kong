 Drive  39570.0\n"]}]},{"cell_type":"code","source":["# ================= 線性趨勢 model → 評估 2024 =================\n","import numpy as np\n","import pandas as pd\n","from sklearn.linear_model import LinearRegression\n","from sklearn.metrics import mean_absolute_error, mean_squared_error\n","\n","# 1) 確保有 link_key（如果你之前已經建好，可以刪掉這一小段）\n","if \"link_key\" not in df_central.columns:\n","    # 沒有 RoadFrom/RoadTo 的話，就用 RoadName + StationNo 之類組合\n","    df_central[\"RoadName_std\"] = (\n","        df_central[\"RoadName\"].fillna(\"\").str.strip().str.upper()\n","    )\n","    df_central[\"link_key\"] = (\n","        df_central[\"RoadName_std\"].astype(str) + \"|\" +\n","        df_central[\"StationNo\"].astype(str)\n","    )\n","\n","# 2) 切出 2019–2023 當訓練資料，2024 當要評估的目標年\n","df_trend = df_central[df_central[\"year\"].between(2019, 2023)].copy()\n","df_2024  = df_central[df_central[\"year\"] == 2024].copy()\n","\n","print(\"訓練資料 (2019–2023) 筆數：\", df_trend.shape)\n","print(\"2024 資料筆數：\", df_2024.shape)\n","\n","# 3) 對每個 link_key 做線性回歸，外插到 2024\n","pred_list = []\n","\n","for key, g in df_trend.groupby(\"link_key\"):\n","    X = g[\"year\"].values.reshape(-1, 1)\n","    y = g[\"CurAADT\"].values\n","\n","    # 至少要兩個不同年份才能 fit 線性趨勢\n","    if len(np.unique(X)) < 2:\n","        continue\n","\n","    model = LinearRegression()\n","    model.fit(X, y)\n","\n","    # 預測 2024\n","    y2024_pred = model.predict(np.array([[2024]]))[0]\n","\n","    pred_list.append({\n","        \"link_key\": key,\n","        \"CurAADT_pred_2024\": y2024_pred\n","    })\n","\n","df_pred_2024 = pd.DataFrame(pred_list)\n","print(\"有線性預測的 2024 路段數：\", df_pred_2024.shape)\n","\n","# 4) 把「真實 2024」跟「預測 2024」合併 → df_linear_24_join\n","df_linear_24_join = (\n","    df_2024[[\"link_key\", \"CurAADT\"]]   # 真實 2024\n","    .merge(df_pred_2024, on=\"link_key\", how=\"inner\")\n",")\n","\n","print(\"\\n用來評估線性趨勢 model 的表：\", df_linear_24_join.shape)\n","print(df_linear_24_join.head().to_string(index=False))\n","\n","# 5) 從 df_linear_24_join 取出 trues_2024 / preds_2024，計算誤差\n","trues_2024 = df_linear_24_join[\"CurAADT\"].values\n","preds_2024 = df_linear_24_join[\"CurAADT_pred_2024\"].values\n","\n","mae = mean_absolute_error(trues_2024, preds_2024)\n","mse = mean_squared_error(trues_2024, preds_2024)\n","rmse = np.sqrt(mse)\n","mape = np.mean(\n","    np.abs(trues_2024 - preds_2024) / trues_2024\n",") * 100\n","\n","print(\"\\nlinear trend model – predict 2024 from 2019–2023\")\n","print(f\"MAE  = {mae:,.1f}\")\n","print(f\"RMSE = {rmse:,.1f}\")\n","print(f\"MAPE = {mape:,.2f}%\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"WQJtZZPgGW-9","executionInfo":{"status":"ok","timestamp":1776933220111,"user_tz":-480,"elapsed":132,"user":{"displayName":"Man tik Chan","userId":"08816915228278197018"}},"outputId":"d911d6e5-71b5-44b7-d9dd-0a081f69168e"},"execution_count":83,"outputs":[{"output_type":"stream","name":"stdout","text":["訓練資料 (2019–2023) 筆數： (45, 14)\n","2024 資料筆數： (9, 14)\n","有線性預測的 2024 路段數： (9, 2)\n","\n","用來評估線性趨勢 model 的表： (9, 3)\n","link_key  CurAADT  CurAADT_pred_2024\n"," HK_1007  56460.0            52662.0\n"," HK_1411  48220.0            35641.0\n"," HK_1464  21560.0            21853.0\n"," HK_1608  41300.0            40301.0\n"," HK_1816  36910.0            31336.0\n","\n","linear trend model – predict 2024 from 2019–2023\n","MAE  = 3,227.8\n","RMSE = 4,926.6\n","MAPE = 7.59%\n"]}]},{"cell_type":"code","source":["# ================= 線性趨勢 model → 評估 2024 =================\n","import numpy as np\n","import pandas as pd\n","from sklearn.linear_model import LinearRegression\n","from sklearn.metrics import mean_absolute_error, mean_squared_error\n","\n","# 0) 檢查一下 df_central 存在，而且有 year / CurAADT\n","print(\"df_central shape:\", df_central.shape)\n","print(\"columns:\", df_central.columns.tolist())\n","print(\"years:\", sorted(df_central[\"year\"].unique()))\n","\n","# 1) 若還沒 link_key，就先建一個（可以視情況改）\n","if \"link_key\" not in df_central.columns:\n","    df_central[\"RoadName_std\"] = (\n","        df_central[\"RoadName\"].fillna(\"\").str.strip().str.upper()\n","    )\n","    # 沒有 StationNo 就拿掉，換成你有的欄位\n","    df_central[\"link_key\"] = (\n","        df_central[\"RoadName_std\"].astype(str) + \"|\" +\n","        df_central[\"StationNo\"].astype(str)\n","    )\n","\n","# 2) 分出 2019–2023 做訓練、2024 做評估\n","df_trend = df_central[df_central[\"year\"].between(2019, 2023)].copy()\n","df_2024  = df_central[df_central[\"year\"] == 2024].copy()\n","\n","print(\"訓練資料 (2019–2023) 筆數：\", df_trend.shape)\n","print(\"2024 真實資料筆數：\", df_2024.shape)\n","\n","# 3) 對每個 link_key 做線性回歸，外插到 2024\n","pred_list = []\n","\n","for key, g in df_trend.groupby(\"link_key\"):\n","    X = g[\"year\"].values.reshape(-1, 1)\n","    y = g[\"CurAADT\"].values\n","\n","    # 至少要兩個不同年份才做線性回歸\n","    if len(np.unique(X)) < 2:\n","        continue\n","\n","    model = LinearRegression()\n","    model.fit(X, y)\n","\n","    # 預測 year = 2024\n","    y2024_pred = model.predict(np.array([[2024]]) )[0]\n","\n","    pred_list.append({\n","        \"link_key\": key,\n","        \"CurAADT_pred_2024\": y2024_pred\n","    })\n","\n","df_pred_2024 = pd.DataFrame(pred_list)\n","print(\"有線性預測的路段數：\", df_pred_2024.shape)\n","\n","# 4) 把 真實 2024 + 預測 2024 合併成 df_linear_24_join\n","df_linear_24_join = (\n","    df_2024[[\"link_key\", \"CurAADT\"]]   # 真實 2024\n","    .merge(df_pred_2024, on=\"link_key\", how=\"inner\")\n",")\n","\n","print(\"\\ndf_linear_24_join (評估用表) shape:\", df_linear_24_join.shape)\n","print(df_linear_24_join.head().to_string(index=False))\n","\n","# 5) 從 df_linear_24_join 取出 trues_2024 / preds_2024，計算指標\n","trues_2024 = df_linear_24_join[\"CurAADT\"].values\n","preds_2024 = df_linear_24_join[\"CurAADT_pred_2024\"].values\n","\n","mae = mean_absolute_error(trues_2024, preds_2024)\n","mse = mean_squared_error(trues_2024, preds_2024)\n","rmse = np.sqrt(mse)\n","mape = np.mean(\n","    np.abs(trues_2024 - preds_2024) / trues_2024\n",") * 100\n",