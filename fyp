al shape:\", df_central.shape)\n","print(\"years:\", sorted(df_central[\"year\"].unique()))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"dhmDLds4I55y","executionInfo":{"status":"ok","timestamp":1776933234102,"user_tz":-480,"elapsed":41,"user":{"displayName":"Man tik Chan","userId":"08816915228278197018"}},"outputId":"b9babdd8-000d-4324-a058-04c4f0e601d8"},"execution_count":94,"outputs":[{"output_type":"stream","name":"stdout","text":["df_central shape: (54, 15)\n","years: [np.int64(2019), np.int64(2020), np.int64(2021), np.int64(2022), np.int64(2023), np.int64(2024)]\n"]}]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","from sklearn.linear_model import LinearRegression\n","from IPython.display import display\n","\n","# 1) 歷史 + 2024 預測\n","def show_historical(link_key):\n","    sub = df_central[df_central[\"link_key\"] == link_key].copy()\n","    sub = sub[sub[\"year\"].between(2019, 2024)].sort_values(\"year\")\n","\n","    if sub.empty:\n","        print(\"這條路在 2019–2024 沒有資料。\")\n","        return\n","\n","    # 線性模型用 2019–2023 預測 2024\n","    train = sub[sub[\"year\"].between(2019, 2023)]\n","    y2024_pred = None\n","    if train[\"year\"].nunique() >= 2:\n","        X = train[[\"year\"]].values\n","        y = train[\"CurAADT\"].values\n","        model = LinearRegression()\n","        model.fit(X, y)\n","        y2024_pred = model.predict(np.array([[2024]]) )[0]\n","\n","    fig, ax = plt.subplots(figsize=(6, 4))\n","    ax.plot(sub[\"year\"], sub[\"CurAADT\"], marker=\"o\", label=\"Actual CurAADT\")\n","\n","    if y2024_pred is not None:\n","        ax.scatter([2024], [y2024_pred], color=\"red\", label=\"Linear prediction (2024)\")\n","\n","    road_name = sub[\"RoadName\"].iloc[0]\n","    ax.set_title(f\"{road_name}\\n({link_key})\")\n","    ax.set_xlabel(\"Year\")\n","    ax.set_ylabel(\"CurAADT\")\n","    ax.grid(True, alpha=0.3)\n","    ax.legend()\n","    plt.show()\n","\n","    display(sub[[\"year\", \"CurAADT\"]])\n","\n","\n","# 2) 未來 2025–2027 預測\n","def show_future(link_key):\n","    sub = df_central[df_central[\"link_key\"] == link_key].copy()\n","    sub = sub[sub[\"year\"].between(2019, 2024)].sort_values(\"year\")\n","\n","    if sub[\"year\"].nunique() < 2:\n","        print(\"這條路資料年份太少，無法做線性趨勢。\")\n","        return\n","\n","    X_train = sub[[\"year\"]].values\n","    y_train = sub[\"CurAADT\"].values\n","    model = LinearRegression()\n","    model.fit(X_train, y_train)\n","\n","    future_years = np.array([2025, 2026, 2027])\n","    X_future = future_years.reshape(-1, 1)\n","    y_future = model.predict(X_future)\n","\n","    fig, ax = plt.subplots(figsize=(6, 4))\n","    ax.plot(sub[\"year\"], sub[\"CurAADT\"], marker=\"o\", label=\"Actual (2019–2024)\")\n","    ax.plot(future_years, y_future, marker=\"x\", linestyle=\"--\", color=\"orange\",\n","            label=\"Forecast (2025–2027)\")\n","\n","    road_name = sub[\"RoadName\"].iloc[0]\n","    ax.set_title(f\"{road_name}\\n({link_key})\")\n","    ax.set_xlabel(\"Year\")\n","    ax.set_ylabel(\"CurAADT\")\n","    ax.grid(True, alpha=0.3)\n","    ax.legend()\n","    plt.show()\n","\n","    df_future = pd.DataFrame({\n","        \"year\": future_years,\n","        \"CurAADT_pred\": y_future\n","    })\n","    display(df_future)\n","\n","\n","# 3) 某一年的 Top 增加 / 減少\n","def show_top_change(year):\n","    sub = df_central[df_central[\"year\"] == year].copy()\n","    if sub.empty:\n","        print(f\"{year} 年沒有 Central 資料。\")\n","        return\n","\n","    if \"ChangeAADT\" not in sub.columns:\n","        print(\"資料裡沒有 ChangeAADT 欄位，無法排名增減。\")\n","        display(sub.head())\n","        return\n","\n","    top_inc = sub.sort_values(\"ChangeAADT\", ascending=False).head(10)\n","    top_dec = sub.sort_values(\"ChangeAADT\", ascending=True).head(10)\n","\n","    print(f\"\\n{year} 年 Central – Top 10 增加最多：\")\n","    display(top_inc[[\"RoadName\", \"RoadFrom\", \"RoadTo\",\n","                     \"PreAADT\", \"CurAADT\", \"ChangeAADT\", \"link_key\"]])\n","\n","    print(f\"\\n{year} 年 Central – Top 10 減少最多：\")\n","    display(top_dec[[\"RoadName\", \"RoadFrom\", \"RoadTo\",\n","                     \"PreAADT\", \"CurAADT\", \"ChangeAADT\", \"link_key\"]])"],"metadata":{"id":"aGGHfwN7I8cW","executionInfo":{"status":"ok","timestamp":1776933234122,"user_tz":-480,"elapsed":18,"user":{"displayName":"Man tik Chan","userId":"08816915228278197018"}}},"execution_count":95,"outputs":[]},{"cell_type":"code","source":["import ipywidgets as widgets\n","from ipywidgets import interact, interactive_output, HBox, VBox\n","\n","# 準備路段下拉清單\n","link_df = (\n","    df_central[[\"link_key\", \"RoadName\"]]\n","    .drop_duplicates()\n","    .sort_values(\"RoadName\")\n",")\n","\n","link_labels = [f\"{row.RoadName} ({row.link_key})\" for _, row in link_df.iterrows()]\n","link_keys = [row.link_key for _, row in link_df.iterrows()]\n","label_to_key = dict(zip(link_labels, link_keys))\n","\n","dropdown_link = widgets.Dropdown(\n","    options=link_labels,\n","    description=\"選擇路段\",\n","    layout=widgets.Layout(width=\"400px\")\n",")\n","\n","# 模式選擇\n","mode_widget = widgets.ToggleButtons(\n","    options=[\"歷史 + 2024\", \"未來預測 2025–2027\", \"Top 增加/減少\"],\n","    description=\"模式\",\n","    button_style=\"\"\n",")\n","\n","# 年份選擇（給 Top 模式用）\n","years_available = sorted(df_central[\"year\"].dropna().unique().tolist())\n","year_widget = widgets.Dropdown(\n","    options=years_available,\n","    description=\"年份\",\n","    value=max(y for y in years_available if y <= 2024)\n",")\n","\n","# 主函式：根據模式呼叫不同畫圖\n","def main_ui(mode, link_label, year):\n","    print(\"\")  # 讓輸出有點空行好看一點\n","    if mode == \"歷史 + 2024\":\n","        key = label_to_key[link_label]\n","        show_historical(key)\n","    elif mode == \"未來預測 2025–2027\":\n","        key = label_to_key[link_label]\n","        show_future(key)\n","    else:  # Top 增加/減少\n","        show_top_change(year)\n","\n","# 用 interactive_output 把元件連起來\n","out = interactive_output(\n","    main_ui,\n","    {\n","        \"mode\": mode_widget,\n","        \"link_label\": dropdown_link,\n","        \"year\": year_widget,\n","    }\n",")\n","\n","# 介面 layout\n","ui_left = VBox([mode_widget, dropdown_link, year_widget])\n","ui = HBox([ui_left, out])\n","display(ui)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":669,"referenced_widgets":["593af7e7a58c4aca83207a89b1d32084","d4647859f40a4374bb0d8265d0035539","1e64f93e640f4331acdb827ccb443627","b091a2b07f3447e0ae7af78da8b99bdb","e978d1bfcdd64b5c8d4c4a4b7679a696","41680627eb7f464ea92555ff12716e59","d82b80b94e4343d89a86374655cb7a47","aefdb78f127a4e9aa3db717dafecd469","4bc6490ae32c45e1b14bafbc26ac5b26","02a83a1ee44e41c9a192187d5c99a510","9f773a152efc4099ae48290ef8634a81","4f287fad7a9e4fbcbf11fea58f69fd14","a5190420c21f4f4ab7371a56e585d08f","a2f187945a7e487191266e4f3904d998","0a717cf381b141f891d7d191816721b9"]},"id":"5zo__MvJJBMb","executionInfo":{"status":"ok","timestamp":1776933234896,"user_tz":-480,"elapsed":759,"user":{"displayName":"Man tik Chan","userId":"08816915228278197018"}},"outputId":"bfac67bc-b2d1-4c36-c74e-e17d325a78d0"},"execution_count":96,"outputs":[{"output_type":"display_data","data":{"text/plain":["HBox(children=(VBox(children=(ToggleButtons(description='模式', options=('歷史 + 2024', '未來預測 2025–2027', 'Top 增加/…"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"593af7e7a58c4aca83207a89b1d32084"}},"metadata":{"application/vnd.jupyter.widget-view+json":{"colab":{"custom_widget_manager":{"url":"https://ssl.gstatic.com/colaboratory-static/widgets/colab-cdn-widget-manager/2b70e893a8ba7c0f/manager.min.js"}}}}}]},{"cell_type":"code","source":["!pip install streamlit joblib pandas"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"PHX3miSOd45v","executionInfo":{"status":"ok","timestamp":1776933242882,"user_tz":-480,"elapsed":7982,"user":{"displayName":"Man tik Chan","userId":"0881691522