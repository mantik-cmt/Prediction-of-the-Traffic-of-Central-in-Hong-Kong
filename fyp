ion(\"display.max_columns\", None)\n","pd.set_option(\"display.width\", 160)\n","\n","# --------- 1. Infer year from filename ---------\n","def infer_year_from_filename(filename: str) -> int:\n","    \"\"\"\n","    適用檔名：\n","      GISDB18.xml  -> 2018\n","      GISDB19.xml  -> 2019\n","      GISDB20.xml  -> 2020, etc.\n","    \"\"\"\n","    stem = os.path.splitext(os.path.basename(filename))[0]  # e.g. \"GISDB19\"\n","    digits = \"\".join(ch for ch in stem if ch.isdigit())\n","    if len(digits) == 2:      # \"19\"\n","        return 2000 + int(digits)\n","    elif len(digits) == 4:    # \"2019\"\n","        return int(digits)\n","    else:\n","        raise ValueError(f\"Cannot infer year from {filename}\")\n","\n","# --------- 2. Read & clean one XML file ---------\n","def read_one_gisdb_xml(path: str) -> pd.DataFrame:\n","    year = infer_year_from_filename(path)\n","    df = pd.read_xml(path, xpath=\".//PStnList\")\n","\n","    # Convert number columns\n","    for col in [\"PreAADT\", \"CurAADT\", \"ChangeAADT\"]:\n","        if col in df.columns:\n","            df[col] = (\n","                df[col]\n","                .astype(str)\n","                .str.replace(\",\", \"\", regex=False)\n","                .str.strip()\n","                .replace(\"\", np.nan)\n","                .astype(float)\n","            )\n","\n","    # Add year\n","    df[\"year\"] = year\n","\n","    # StationNo numeric and link_key\n","    df[\"StationNo\"] = pd.to_numeric(df[\"StationNo\"], errors=\"coerce\")\n","    df[\"link_key\"] = (\n","        df[\"Regional\"].fillna(\"\") + \"_\" +\n","        df[\"StationNo\"].fillna(-1).astype(int).astype(str)\n","    )\n","\n","    # ID as integer (nullable)\n","    df[\"ID\"] = pd.to_numeric(df[\"ID\"], errors=\"coerce\").astype(\"Int64\")\n","\n","    return df\n","\n","# --------- 3. Load ALL GISDB*.xml from Google Drive ---------\n","# 重要：這裡改成你的 Google Drive AADT_files 路徑\n","XML_DIR = \"/content/drive/MyDrive/AADT_files\"\n","\n","# 這個 pattern 會抓到：\n","#   /content/drive/MyDrive/AADT_files/2019/GISDB19.xml\n","#   /content/drive/MyDrive/AADT_files/2020/GISDB20.xml\n","#   /content/drive/MyDrive/AADT_files/2021/GISDB21.xml\n","#   /content/drive/MyDrive/AADT_files/2022/GISDB22.xml\n","#   /content/drive/MyDrive/AADT_files/2023/2023/GISDB23.xml\n","xml_files = glob.glob(os.path.join(XML_DIR, \"**\", \"GISDB*.xml\"), recursive=True)\n","\n","if not xml_files:\n","    raise SystemExit(\n","        \"在 /content/drive/MyDrive/AADT_files 底下找不到任何 GISDB*.xml 檔案。\\n\"\n","        \"請確認 Google Drive 已掛載，且檔案路徑正確。\"\n","    )\n","\n","print(\"XML files found:\")\n","for f in sorted(xml_files):\n","    print(\"  \", f)\n","\n","# --------- 4. Read and combine all years ---------\n","all_years = []\n","for path in sorted(xml_files):\n","    try:\n","        print(f\"\\nReading {os.path.basename(path)} ...\")\n","        tmp = read_one_gisdb_xml(path)\n","        print(\"  rows:\", tmp.shape[0])\n","        all_years.append(tmp)\n","    except Exception as e:\n","        print(\"  ERROR, skipped:\", e)\n","\n","df_all = pd.concat(all_years, ignore_index=True)\n","print(\"\\nCombined dataset shape:\", df_all.shape)\n","print(\"\\nColumns:\", df_all.columns.tolist())\n","print(\"\\nFirst 5 rows:\")\n","print(df_all.head().to_string(index=False))\n","\n","# --------- 5. Quick checks ---------\n","print(\"\\nYears:\", sorted(df_all[\"year\"].unique()))\n","print(\"Regions:\", df_all[\"Regional\"].unique())\n","print(\"Road types:\", df_all[\"RoadType\"].unique())\n","\n","# --------- 6. Example: Harcourt Road over years ---------\n","example_key = \"HK_1001\"  # 這個只是示例，之後你可以改成實際存在的 link_key\n","df_link = (\n","    df_all[df_all[\"link_key\"] == example_key]\n","    .sort_values(\"year\")\n","    [[\"year\",\"Regional\",\"StationNo\",\"RoadName\",\"PreAADT\",\"CurAADT\",\"ChangeAADT\"]]\n",")\n","print(f\"\\nExample link_key = {example_key}\")\n","if df_link.empty:\n","    print(\"  (No rows found; choose a different link_key.)\")\n","else:\n","    print(df_link.to_string(index=False))\n","    plt.figure(figsize=(5,3))\n","    plt.plot(df_link[\"year\"], df_link[\"CurAADT\"], marker=\"o\")\n","    plt.title(f\"CurAADT – {example_key}\")\n","    plt.xlabel(\"Year\")\n","    plt.ylabel(\"CurAADT\")\n","    plt.grid(True, alpha=0.3)\n","    plt.tight_layout()\n","    plt.show()\n","\n","# --------- 7. Save to CSV ---------\n","# 這裡你可以選擇存到 /content（暫存）或直接存回 Drive\n","out_path = \"/content/drive/MyDrive/AADT_files/hk_aadt_all_years.csv\"\n","df_all.to_csv(out_path, index=False, encoding=\"utf-8-sig\")\n","print(\"\\nSaved combined CSV to:\", out_path)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"a3iQgRdHeNv8","executionInfo":{"status":"ok","timestamp":1776933215999,"user_tz":-480,"elapsed":2077,"user":{"displayName":"Man tik Chan","userId":"08816915228278197018"}},"outputId":"68ca64b3-a21c-4c55-e596-39fd5f14e941"},"execution_count":76,"outputs":[{"output_type":"stream","name":"stdout","text":["XML files found:\n","   /content/drive/MyDrive/AADT_files/2019/GISDB19.xml\n","   /content/drive/MyDrive/AADT_files/2020/GISDB20.xml\n","   /content/drive/MyDrive/AADT_files/2021/GISDB21.xml\n","   /content/drive/MyDrive/AADT_files/2022/GISDB22.xml\n","   /content/drive/MyDrive/AADT_files/2023/2023/GISDB23.xml\n","   /content/drive/MyDrive/AADT_files/2024/2024/GISDB24.xml\n","\n","Reading GISDB19.xml ...\n","  rows: 1666\n","\n","Reading GISDB20.xml ...\n","  rows: 1664\n","\n","Reading GISDB21.xml ...\n","  rows: 1677\n","\n","Reading GISDB22.xml ...\n","  rows: 1686\n","\n","Reading GISDB23.xml ...\n","  rows: 1690\n","\n","Reading GISDB24.xml ...\n","  rows: 1694\n","\n","Combined dataset shape: (10077, 14)\n","\n","Columns: ['ID', 'Regional', 'StationNo', 'StationType', 'RoadType', 'RoadNetwork', 'RoadName', 'RoadFrom', 'RoadTo', 'PreAADT', 'CurAADT', 'ChangeAADT', 'year', 'link_key']\n","\n","First 5 rows:\n","  ID Regional  StationNo StationTyp